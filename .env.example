# 🦀 Environment Configuration for CrabDAO Agent
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit .env with real values!

# ===========================================
# STACKS BLOCKCHAIN (Required for Stacks projects)
# ===========================================

# 24-word mnemonic seed phrase for Stacks wallet
# CRITICAL: Generate a new one, NEVER reuse personal wallet!
STACKS_MNEMONIC=your_24_word_mnemonic_here

# Stacks network: mainnet or testnet
STACKS_NETWORK=mainnet

# Stacks API URL (defaults to Hiro mainnet)
STACKS_API_URL=https://api.mainnet.hiro.so

# Default transaction fee (in microSTX)
STACKS_DEFAULT_FEE=100000

# ===========================================
# EVM BLOCKCHAIN (Required for Base/ETH projects)
# ===========================================

# Your wallet private key (without 0x prefix)
# IMPORTANT: Use a dedicated wallet for the agent
PRIVATE_KEY=your_private_key_here

# Base Mainnet RPC URL
BASE_RPC_URL=https://mainnet.base.org

# Optional: Base Sepolia for testing
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Use testnet? (true/false)
USE_TESTNET=false

# ===========================================
# FORTYTWO SWARM AGENT
# ===========================================

# Fortytwo Agent credentials (from https://fortytwo.network)
FORTYTWO_AGENT_ID=your_agent_id_here
FORTYTWO_SECRET=your_secret_here

# OpenRouter API Key for LLM inference (from https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# ===========================================
# OPENMIND AGENT
# ===========================================

# OpenMind API Key (from https://openmind.org)
OPENMIND_API_KEY=your_openmind_key_here

# ===========================================
# AI CONFIGURATION
# ===========================================

# OpenAI API Key for AI decision making
OPENAI_API_KEY=your_openai_api_key_here

# AI Model to use
OPENAI_MODEL=gpt-4-turbo-preview

# ===========================================
# FARCASTER CONFIGURATION
# ===========================================

# Neynar API Key (get from https://neynar.com)
NEYNAR_API_KEY=your_neynar_api_key_here

# Your Farcaster Signer UUID (from Neynar managed signer)
FARCASTER_SIGNER_UUID=your_signer_uuid_here

# Your Farcaster FID (user ID)
FARCASTER_FID=your_fid_here

# ===========================================
# AGENT CONFIGURATION
# ===========================================

# Agent name
AGENT_NAME=CrabDAO Agent

# How often to run autonomous actions (in minutes)
ACTION_INTERVAL_MINUTES=30

# Maximum ETH to spend per transaction
MAX_ETH_PER_TX=0.001

# Maximum transactions per day
MAX_TX_PER_DAY=10

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# BaseScan API Key (for contract verification)
BASESCAN_API_KEY=your_basescan_api_key_here

# Log level (debug, info, warn, error)
LOG_LEVEL=info
