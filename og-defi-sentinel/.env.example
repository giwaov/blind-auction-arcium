# =============================================================================
# DeFi Sentinel — OpenGradient Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# REQUIRED: OpenGradient private key (Ethereum-compatible, funded with $OPG on Base Sepolia)
# Get testnet tokens from: https://faucet.opengradient.ai
OG_PRIVATE_KEY=0x_your_private_key_here

# OPTIONAL: MemSync API key for persistent memory across sessions
# Get your key from: https://app.memsync.ai/dashboard/api-keys
MEMSYNC_API_KEY=your_memsync_api_key_here
